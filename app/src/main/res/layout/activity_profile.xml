<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".ProfileActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/profileHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="PROFILE"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Profile Info -->
    <LinearLayout
        android:id="@+id/profileInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/profileHeader">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/white"
            app:strokeWidth="4dp" />

        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="James Carter"
            android:textColor="@color/text_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProfileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="james.carter@email.com"
            android:textColor="@color/text_hint"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Menu Options -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/profileInfo">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPaymentMethods"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:text="Payment Methods"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_manage"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:text="Settings"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_preferences"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:text="Logout"
            android:textColor="#E53935"
            app:icon="@android:drawable/ic_lock_power_off"
            app:iconTint="#E53935" />

    </LinearLayout>

    <!-- Bottom Nav (Consistent) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/glass_white"
        app:cardCornerRadius="36dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:strokeColor="@color/glass_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/navHome"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_today" />

            <ImageView
                android:id="@+id/navHistory"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_recent_history" />

            <ImageView
                android:id="@+id/navNotifications"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:src="@android:drawable/ic_popup_reminder" />

            <ImageView
                android:id="@+id/navProfile"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:background="@drawable/bg_nav_active"
                android:src="@android:drawable/ic_menu_myplaces" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>