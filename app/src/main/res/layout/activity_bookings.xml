<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".BookingsActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/bookingsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="MY BOOKINGS"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tabs (Simplified for now) -->
    <HorizontalScrollView
        android:id="@+id/tabScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/bookingsHeader">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_active"
                android:paddingHorizontal="24dp"
                android:paddingVertical="8dp"
                android:text="All"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Completed"
                android:textColor="@color/text_hint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="In Process"
                android:textColor="@color/text_hint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Cancelled"
                android:textColor="@color/text_hint" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBookings"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintTop_toBottomOf="@id/tabScroll"
        tools:listitem="@layout/item_booking" />

    <!-- Bottom Nav (Shared style) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/glass_white"
        app:cardCornerRadius="36dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:strokeColor="@color/glass_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/navHome"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_today" />

            <ImageView
                android:id="@+id/navHistory"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:background="@drawable/bg_nav_active"
                android:src="@android:drawable/ic_menu_recent_history" />

            <ImageView
                android:id="@+id/navNotifications"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:src="@android:drawable/ic_popup_reminder" />

            <ImageView
                android:id="@+id/navProfile"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_myplaces" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>